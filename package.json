{
  "name": "devdiggers-wallet-for-woocommerce",
  "version": "1.0.0",
  "description": "DevDiggers Wallet for WooCommerce",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build-old": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack",
    "example": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --config extensions/extensions.config.js --watch",
    "watch": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --watch",
    "build": "cross-env NODE_ENV=production NODE_OPTIONS=--openssl-legacy-provider webpack",
    "production": "cross-env NODE_ENV=production NODE_OPTIONS=--openssl-legacy-provider webpack",
    "build:release": "sh ./bin/build-plugin-zip.sh",
    "postbuild": "npm run replace-textdomain && npm run i18n",
    "replace-textdomain": "node bin/replace-textdomain.js",
    "i18n": "npm run -s i18n:js && npm run -s i18n:check && npm run -s i18n:pot && npm run -s i18n:build && npm run i18n:json",
    "i18n:build": "php bin/combine-pot-files.php i18n/devdiggers-wallet-for-woocommerce.po i18n/devdiggers-wallet-for-woocommerce.pot",
    "i18n:check": "grunt checktextdomain",
    "i18n:js": "cross-env NODE_ENV=production babel src -o /dev/null",
    "i18n:json": "sh ./bin/make-i18n-json.sh",
    "i18n:pot": "grunt makepot",
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --watch"
  },
  "author": "devdiggers",
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^7.14.5",
    "@babel/core": "7.7.7",
    "@babel/plugin-transform-async-to-generator": "7.7.4",
    "@babel/plugin-transform-react-jsx": "7.7.7",
    "@babel/preset-stage-0": "^7.0.0",
    "@babel/preset-typescript": "^7.13.0",
    "@babel/runtime-corejs2": "^7.29.2",
    "@wordpress/babel-plugin-import-jsx-pragma": "1.1.3",
    "@wordpress/babel-plugin-makepot": "2.1.3",
    "@wordpress/babel-preset-default": "3.0.2",
    "babel-core": "7.0.0-bridge.0",
    "babel-loader": "8.0.6",
    "babel-plugin-transform-class-properties": "6.24.1",
    "babel-plugin-transform-es2015-template-literals": "6.22.0",
    "cross-env": "6.0.3",
    "css-loader": "3.4.0",
    "css-minimizer-webpack-plugin": "^3.0.2",
    "grunt": "^1.6.1",
    "grunt-checktextdomain": "1.0.1",
    "grunt-wp-i18n": "1.0.3",
    "less": "^3.9.0",
    "less-loader": "^4.1.0",
    "mini-css-extract-plugin": "0.9.0",
    "node-watch": "0.6.3",
    "postcss-color-function": "4.1.0",
    "postcss-loader": "^3.0.0",
    "rtlcss": "2.4.1",
    "style-loader": "0.23.1",
    "stylelint": "^13.13.1",
    "stylelint-config-wordpress": "13.1.0",
    "terser-webpack-plugin": "^1.4.5",
    "url-loader": "1.1.2",
    "webpack": "^5.106.1",
    "webpack-cli": "3.3.10"
  },
  "dependencies": {
    "@wordpress/element": "2.8.1",
    "chart.js": "^4.5.1",
    "npm-watch": "^0.13.0",
    "watch": "^1.0.2"
  }
}